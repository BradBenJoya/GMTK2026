[node name="FlavorTextController" type="Node" parent="." unique_id=1545654535]
script = ExtResource("2_hkori")
read_text = Array[String](["Boss - Job Stuff \\n\\n Get back to work or else I'm not paying you! Seriously.", "Bob - Party at my house tonight! \\n\\n We're gonna have pizza, soda, and Jenny is gonna be there. ;) \\n \"maps.google.com/3728_ud890_2\"", "Wife - Store \\n\\n I'm going to the store to get groceries. Do you need anything? \\n I'm getting tomatoes, olives, bread, and a little surprise if you come home early! ;)", "User1426 - Glitch in your system \\n\\n I filled out the form, but your company keeps charging me! If this keeps up I'm going to sue!", "Boss - Jill has called in sick and won't be here for the next couple of weeks. \\n\\n Just thought to let you know.", "kid_jensen_11 - math \\n\\n hi whats 4*3 my math teacher wont tell me"])
decision_good_text = Array[String](["Boss - Job Stuff \\n\\n Want a raise? Your acceptional work has been recognised by the other staff.", "Discord - Nitro! \\n\\n You got gifted 1 Month of Nitro! Do you accept?", "Colin - Report Due \\n\\n I handled the report. Should I send it to you so you can submit it?"])
decision_bad_text = Array[String](["Susie - Bob \\n\\n Should we fire Bob? He's really annoying. Like REALLY. I know you guys are friends, but...", "Wife - Be with me \\n\\n Take a day off! You could help around the house instead of being at work! \\n\\n\\n You might lose your job but it's worth it!", "H@CKER12345 - YOU'VED BEEN HACKED \\n\\n Hehehe! Give me money or you'll lose everything!"])
spam_text = Array[String](["LOTTERY - $$$$ \\n\\n You wun $10,,000!1!!!!11!!!", "Amasun - Pakage send problm \\n\\n Plz confirm your acount we need to confrm it", "Itchy - you got hacker'ed smackered \\n\\n Ur account got hackd. Please call 123-456-7890 to reset ur pasword."])
upload_text = Array[String](["Jack - Little mistake \\n\\n Could you send me the tax forms file? I think I deleted my copy.", "Boss - Report Due \\n\\n I need that report NOW! What's taking so long!"])

