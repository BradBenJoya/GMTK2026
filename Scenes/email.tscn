decision_bad_text = Array[String](["Susie - Should we fire Bob? He's been slacking off lately and we can't tell if he's actually in this company", "Wife - Take a day off! You could help around the house instead of being at work!", "H@CKER12345 - Hehehe! Give me money or you'll lose everything!"])
